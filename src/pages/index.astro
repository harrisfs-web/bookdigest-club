---
import Layout from "../layouts/Layout.astro";
import BookCard from "../components/BookCard.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";
import { getCategoryPath, getTopBookCategories } from "../lib/bookCategories";

const books = await getCollection("books");
const featuredBooks = books.slice(0, 3); // Show first 3 books as featured
const topCategories = getTopBookCategories(books, 5);
---
<Layout title="BookDigest – AI-Powered Book Summaries" description="Discover AI-powered concise book summaries and recommendations for busy readers.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-gray-900 to-gray-800 text-white min-h-[70vh] flex items-center hero-mobile">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20 w-full">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-4 sm:mb-6 text-white leading-tight">
          BookDigest
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-gray-300 mb-6 sm:mb-8 leading-relaxed max-w-3xl mx-auto px-4 sm:px-0 mobile-large-text">
          Discover AI-powered concise book summaries and recommendations for busy readers
        </p>
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center max-w-md sm:max-w-none mx-auto px-4 sm:px-0">
          <a href="/books" class="btn-primary bg-accent-500 hover:bg-accent-600 text-gray-900 font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-xl text-base sm:text-lg transition-all duration-300 hover:scale-105 w-full sm:w-auto text-center mobile-button" data-gtm-event="cta_click" data-click-content="Browse Summaries">
            Browse Summaries
          </a>
          <a href="#featured" class="btn-secondary bg-white/10 hover:bg-white/20 text-white font-semibold px-6 sm:px-8 py-3 sm:py-4 rounded-xl text-base sm:text-lg transition-all duration-300 backdrop-blur-sm w-full sm:w-auto text-center mobile-button" data-gtm-event="cta_click" data-click-content="Featured Books">
            Featured Books
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-12 sm:py-16 lg:py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 sm:mb-16">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 sm:mb-4 mobile-large-heading">Why Choose BookDigest?</h2>
        <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto px-4 sm:px-0 mobile-large-text">Transform your reading experience with AI-powered insights</p>
      </div>
      
      <div class="grid gap-6 sm:gap-8 md:grid-cols-3">
        <div class="text-center p-4 sm:p-6 bg-white rounded-xl shadow-sm mobile-card">
          <div class="w-14 h-14 sm:w-16 sm:h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-2 mobile-medium-heading">AI-Powered Insights</h3>
          <p class="text-sm sm:text-base text-gray-600 mobile-medium-text">Get the key takeaways from bestselling books in just minutes</p>
        </div>
        
        <div class="text-center p-4 sm:p-6 bg-white rounded-xl shadow-sm mobile-card">
          <div class="w-14 h-14 sm:w-16 sm:h-16 bg-accent-100 rounded-full flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-accent-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-2 mobile-medium-heading">Quick & Actionable</h3>
          <p class="text-sm sm:text-base text-gray-600 mobile-medium-text">Digestible summaries you can read in under 10 minutes</p>
        </div>
        
        <div class="text-center p-4 sm:p-6 bg-white rounded-xl shadow-sm md:col-span-1 sm:col-span-2 md:col-span-1 sm:max-w-md sm:mx-auto md:max-w-none md:mx-0 mobile-card">
          <div class="w-14 h-14 sm:w-16 sm:h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
            </svg>
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-2 mobile-medium-heading">Curated Selection</h3>
          <p class="text-sm sm:text-base text-gray-600 mobile-medium-text">Handpicked bestsellers across business, self-help, and more</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Books Section -->
  <section id="featured" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 mobile-large-heading">Featured Book Summaries</h2>
        <p class="text-xl text-gray-600 mobile-large-text">Start your learning journey with these popular picks, then keep exploring by category.</p>

        {topCategories.length > 0 && (
          <div class="mt-6 flex flex-wrap justify-center gap-3">
            {topCategories.map((category) => (
              <a
                href={getCategoryPath(category.slug)}
                class="inline-flex items-center gap-2 rounded-full border border-primary-100 bg-primary-50 px-4 py-2 text-sm font-medium text-primary-700 transition-colors hover:border-primary-200 hover:bg-primary-100"
                data-gtm-event="category_click"
                data-click-content={category.name}
              >
                <span>{category.name}</span>
                <span class="rounded-full bg-white px-2 py-0.5 text-xs font-semibold text-primary-700">{category.count}</span>
              </a>
            ))}
          </div>
        )}
      </div>
      
      <div class="grid md:grid-cols-3 gap-8 mb-12 recommendations-grid">
        {featuredBooks.map((book) => (
          <BookCard book={book} variant="compact" showTags={true} tagLimit={2} />
        ))}
      </div>
      
      <div class="text-center">
  <a href="/books" class="btn-primary inline-flex items-center space-x-2 px-8 py-3 rounded-xl text-lg font-semibold mobile-button" data-gtm-event="cta_click" data-click-content="View All Summaries">
          <span>View All Summaries</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <Newsletter />
</Layout>