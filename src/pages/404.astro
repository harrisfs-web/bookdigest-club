---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BookCard from "../components/BookCard.astro";
import { getTopBookCategories, getCategoryPath } from "../lib/bookCategories";

const allBooks = await getCollection("books");
const popularBooks = [...allBooks]
  .sort((a, b) => b.data.rating - a.data.rating)
  .slice(0, 3);
const topCategories = getTopBookCategories(allBooks, 6);
---

<Layout
  title="Page Not Found – BookDigest"
  description="This page doesn't exist, but we have great book summaries to explore."
  robots="noindex, follow"
>
  <!-- 404 Hero -->
  <section class="bg-white py-20 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <p class="text-[9rem] leading-none font-bold text-gray-100 select-none" aria-hidden="true">404</p>
      <h1 class="text-3xl font-bold text-gray-900 mt-2 mb-4">Page not found</h1>
      <p class="text-lg text-gray-600 mb-8">
        The page you're looking for doesn't exist. But there are plenty of great book summaries waiting for you.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-colors"
          data-gtm-event="cta_click"
          data-click-content="404 Go Home"
        >
          ← Go Home
        </a>
        <a
          href="/books"
          class="px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-xl transition-colors"
          data-gtm-event="cta_click"
          data-click-content="404 Browse Books"
        >
          Browse All Books
        </a>
      </div>
    </div>
  </section>

  <!-- Popular Books -->
  {popularBooks.length > 0 && (
    <section class="py-16 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">Our Most Popular Summaries</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {popularBooks.map((book) => (
            <BookCard book={book} variant="compact" />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Browse by Category -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-6">Browse by Category</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {topCategories.map((category) => (
          <a
            href={getCategoryPath(category.slug)}
            class="px-4 py-2 rounded-full border border-gray-200 bg-gray-50 text-sm font-medium text-gray-700 hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700 transition-colors"
            data-gtm-event="category_click"
            data-click-content={category.name}
          >
            {category.name}
            <span class="ml-1.5 text-xs text-gray-500">({category.count})</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
