---
import Layout from "../layouts/Layout.astro";
import Newsletter from "../components/Newsletter.astro";
---

<Layout title="About – BookDigest" description="Learn about BookDigest: our mission and process for crafting concise, actionable book summaries.">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": ["WebPage", "AboutPage"],
      "name": "About BookDigest",
      "url": (Astro.site ? new URL('/about/', Astro.site).toString() : 'https://bookdigest.club/about/'),
      "description": "About BookDigest and our AI-powered summaries.",
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "BookDigest",
      "url": (Astro.site ? new URL('/', Astro.site).toString() : 'https://bookdigest.club/'),
      "logo": (Astro.site ? new URL('/logo.png', Astro.site).toString() : 'https://bookdigest.club/logo.png'),
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": (Astro.site ? new URL('/', Astro.site).toString() : 'https://bookdigest.club/')},
        {"@type": "ListItem", "position": 2, "name": "About", "item": (Astro.site ? new URL('/about/', Astro.site).toString() : 'https://bookdigest.club/about/')}
      ]
    }
  ])} />
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-gray-900 to-gray-800 text-white py-12 sm:py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6 text-white mobile-large-heading">About BookDigest</h1>
      <p class="text-lg sm:text-xl md:text-2xl text-gray-300 leading-relaxed px-4 sm:px-0 mobile-large-text">
        Transforming the way busy professionals consume knowledge through AI-powered book summaries
      </p>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 sm:mb-4 mobile-large-heading">Our Mission</h2>
        <p class="text-base sm:text-lg text-gray-600 leading-relaxed px-4 sm:px-0 mobile-content">
          We believe that everyone deserves access to the world's best ideas, regardless of how busy their schedule is. 
          That's why we created BookDigest – to distill the most valuable insights from bestselling books into 
          concise, actionable summaries you can read in under 10 minutes.
        </p>
      </div>
      
      <div class="bg-gradient-to-br from-primary-50 to-accent-50 p-6 sm:p-8 rounded-2xl mobile-card text-center">
        <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-5 sm:mb-6 mobile-medium-heading">Why Book Summaries & Our Process</h3>
        <div class="flex flex-col items-center space-y-4">
          <div class="flex items-center justify-center space-x-3">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="text-sm sm:text-base mobile-medium-text"><strong>Save Time:</strong> Get key insights without reading 300+ pages</span>
          </div>
          <div class="flex items-center justify-center space-x-3">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="text-sm sm:text-base mobile-medium-text"><strong>Learn More:</strong> Consume 10x more books in the same time</span>
          </div>
          <div class="flex items-center justify-center space-x-3">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="text-sm sm:text-base mobile-medium-text"><strong>Stay Focused:</strong> Get only the most valuable takeaways</span>
          </div>
          <div class="flex items-center justify-center space-x-3">
            <svg class="w-7 h-7 sm:w-8 sm:h-8 text-primary-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            <span class="text-sm sm:text-base mobile-medium-text"><strong>Apply Immediately:</strong> Actionable insights you can use today</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Editorials Section -->
  <section class="py-12 sm:py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 sm:mb-4 mobile-large-heading">About the Editorials</h2>
        <p class="text-base sm:text-lg text-gray-600 leading-relaxed px-4 sm:px-0 mobile-content">
          Short editorial notes are added to selected summaries to provide extra context, clarify common misconceptions, and reinforce the ideas that matter most.
        </p>
      </div>

      <div class="bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 mobile-card">
        <div class="flex items-start gap-4 sm:gap-5">
          <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center shrink-0" aria-hidden="true">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A9.96 9.96 0 0112 15c2.5 0 4.786.918 6.535 2.436M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-3 mobile-medium-heading">Harris F.</h3>
            <p class="text-base sm:text-lg text-gray-700 leading-relaxed mobile-content">
              Harris is an amateur book enthusiast who wants to spread useful information and help readers reinforce what they learn. These editorial notes are written to make big ideas easier to retain and apply.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- Newsletter Section -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 sm:pb-16">
    <Newsletter 
      title="Join Our Reading Community"
      subtitle="Be part of thousands of readers who save time with our AI-powered book summaries. Get exclusive content and early access to new summaries."
    />
  </div>

  <!-- Contact Section -->
  <section class="py-12 sm:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3 sm:mb-4">Get in Touch</h2>
      <p class="text-base sm:text-lg text-gray-600 mb-6 sm:mb-8 px-4 sm:px-0">
        Have a book suggestion or feedback? We'd love to hear from you!
      </p>
      
      <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
        <a href="mailto:hello@bookdigest.club" class="btn-primary px-6 py-2.5 sm:px-8 sm:py-3 rounded-xl font-semibold text-base sm:text-lg">
          📧 Contact Us
        </a>
  <button id="open-suggest-modal" type="button" class="btn-secondary px-6 py-2.5 sm:px-8 sm:py-3 rounded-xl font-semibold text-base sm:text-lg" data-gtm-event="request_book_click" data-click-content="Suggest a Book">
          💡 Suggest a Book
        </button>
        <div id="suggest-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 hidden">
          <div class="bg-white rounded-xl shadow-lg p-4 sm:p-6 w-full max-w-2xl relative">
            <button id="close-suggest-modal" type="button" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            <h4 class="text-lg font-semibold mb-2">Suggest a Book</h4>
            <iframe src="https://docs.google.com/forms/d/e/1FAIpQLScgjIXlYnaHdqYj-in8hSxdoEhQu-kMmX8t4uOj5zAMHvP6tg/viewform?embedded=true" width="100%" height="419" frameborder="0" marginheight="0" marginwidth="0" class="w-full rounded-lg border">Loading…</iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const openBtn = document.getElementById('open-suggest-modal');
    const modal = document.getElementById('suggest-modal');
    const closeBtn = document.getElementById('close-suggest-modal');
    if (openBtn && modal && closeBtn) {
      openBtn.onclick = () => { modal.classList.remove('hidden'); };
      closeBtn.onclick = () => { modal.classList.add('hidden'); };
      modal.onclick = (e) => { if (e.target === modal) closeBtn.onclick(); };
    }
  </script>
</Layout>
