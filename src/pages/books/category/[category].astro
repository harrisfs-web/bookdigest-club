---
import { getCollection } from "astro:content";
import BookCard from "../../../components/BookCard.astro";
import Layout from "../../../layouts/Layout.astro";
import { findBookCategoryBySlug, getBookCategories, getCategoryPath, getTopBookCategories } from "../../../lib/bookCategories";
import Breadcrumb from "../../../components/Breadcrumb.astro";

export async function getStaticPaths() {
  const books = await getCollection("books");
  const categories = getBookCategories(books);

  return categories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const allBooks = await getCollection("books");
const fallbackCategory = findBookCategoryBySlug(allBooks, Astro.params.category ?? "");
const selectedCategory = Astro.props.category ?? fallbackCategory;

if (!selectedCategory) {
  throw new Error(`Category not found: ${Astro.params.category}`);
}

const topCategories = getTopBookCategories(allBooks, 6).filter((category) => category.slug !== selectedCategory.slug);
---

<Layout
  title={`${selectedCategory.name} Books – BookDigest`}
  description={`Browse ${selectedCategory.count} book summaries in ${selectedCategory.name}.`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": ["WebPage", "CollectionPage"],
      "name": `${selectedCategory.name} Book Summaries`,
      "url": (Astro.site ? new URL(getCategoryPath(selectedCategory.slug), Astro.site).toString() : `https://bookdigest.club${getCategoryPath(selectedCategory.slug)}`),
      "description": `Browse ${selectedCategory.count} book summaries in ${selectedCategory.name}.`,
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": (Astro.site ? new URL('/', Astro.site).toString() : 'https://bookdigest.club/')},
        {"@type": "ListItem", "position": 2, "name": "Books", "item": (Astro.site ? new URL('/books/', Astro.site).toString() : 'https://bookdigest.club/books/')},
        {"@type": "ListItem", "position": 3, "name": selectedCategory.name, "item": (Astro.site ? new URL(getCategoryPath(selectedCategory.slug), Astro.site).toString() : `https://bookdigest.club${getCategoryPath(selectedCategory.slug)}`)}
      ]
    }
  ])} />

  <section class="bg-gradient-to-r from-gray-900 to-gray-800 text-white py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: "Home", href: "/" },
        { label: "Books", href: "/books" },
        { label: selectedCategory.name },
      ]} />

      <div class="mt-6 max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary-300">Category</p>
        <h1 class="mt-3 text-4xl sm:text-5xl font-bold mobile-large-heading">{selectedCategory.name}</h1>
        <p class="mt-4 text-lg sm:text-xl text-gray-300 mobile-large-text">
          {selectedCategory.count} summary{selectedCategory.count === 1 ? "" : "ies"} connected by the {selectedCategory.name.toLowerCase()} theme.
        </p>
      </div>

      {topCategories.length > 0 && (
        <div class="mt-8 flex flex-wrap gap-3">
          {topCategories.map((category) => (
            <a
              href={getCategoryPath(category.slug)}
              class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10"
              data-touch-scroll-guard="true"
              data-gtm-event="category_click"
              data-click-content={category.name}
            >
              <span>{category.name}</span>
              <span class="rounded-full bg-white/10 px-2 py-0.5 text-xs font-semibold text-primary-200">{category.count}</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="bg-gray-50 py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600">In This Category</p>
          <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-gray-900">{selectedCategory.name} summaries</h2>
        </div>
        <p class="max-w-xl text-sm sm:text-base text-gray-600">
          These books fall under the {selectedCategory.name.toLowerCase()} category, making it easier to move from one idea cluster to the next.
        </p>
      </div>

      <div class="grid gap-4 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {selectedCategory.books.map((book) => (
          <BookCard book={book} variant="catalog" showTags={true} tagLimit={3} />
        ))}
      </div>
    </div>
  </section>
</Layout>