---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BookCard from "../../components/BookCard.astro";
import Newsletter from "../../components/Newsletter.astro";
import { getBookCategories, getCategoryPath, getTopBookCategories } from "../../lib/bookCategories";
import Breadcrumb from "../../components/Breadcrumb.astro";

const books = await getCollection("books");
const categories = getBookCategories(books);
const topCategories = getTopBookCategories(books, 6);
---

<Layout title="Book Digest – All Summaries" description="Browse all our book summaries with key insights you can read in minutes.">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": ["WebPage", "CollectionPage"],
      "name": "All Book Summaries",
      "url": (Astro.site ? new URL('/books/', Astro.site).toString() : 'https://bookdigest.club/books/'),
      "description": "Explore our complete collection of AI-powered book summaries.",
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": (Astro.site ? new URL('/', Astro.site).toString() : 'https://bookdigest.club/')},
        {"@type": "ListItem", "position": 2, "name": "Books", "item": (Astro.site ? new URL('/books/', Astro.site).toString() : 'https://bookdigest.club/books/')}
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "itemListElement": (
        Array.isArray(books)
          ? books.map((b, i) => ({
              "@type": "ListItem",
              "position": i + 1,
              "item": {
                "@type": "Book",
                "name": b.data?.title,
                "author": b.data?.author,
                "url": (Astro.site ? new URL(`/books/${b.slug}/`, Astro.site).toString() : `https://bookdigest.club/books/${b.slug}/`)
              }
            }))
          : []
      )
    }
  ])} />
  <!-- Header Section -->
  <section class="bg-gradient-to-r from-gray-900 to-gray-800 text-white py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumb items={[
        { label: "Home", href: "/" },
        { label: "Books" },
      ]} />
      <div class="text-center">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4 mobile-large-heading">All Book Summaries</h1>
        <p class="text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto px-4 sm:px-0 mobile-large-text">
          Explore our complete collection of AI-powered book summaries and browse the ideas that connect them.
        </p>
        <div class="mt-6 sm:mt-8 flex flex-wrap justify-center gap-3">
          <span class="bg-primary-600 text-white px-3 py-1.5 sm:px-4 sm:py-2 rounded-full text-sm font-medium mobile-medium-text">
            {books.length} Books Available
          </span>
          <span class="bg-white/10 text-white px-3 py-1.5 sm:px-4 sm:py-2 rounded-full text-sm font-medium mobile-medium-text backdrop-blur-sm">
            {categories.length} Categories to Explore
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Books Grid -->
  <section class="py-12 sm:py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {topCategories.length > 0 && (
        <div class="mb-10 sm:mb-12 rounded-3xl border border-gray-200 bg-white p-6 sm:p-8 shadow-sm">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-primary-600">Browse by Category</p>
              <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-gray-900">Start with the themes readers return to most</h2>
              <p class="mt-2 max-w-2xl text-sm sm:text-base text-gray-600">
                These top-level categories are curated from the underlying book tags, so you can browse broader themes without getting stuck in overly specific labels.
              </p>
            </div>
            <a href="#all-books" class="btn-secondary text-sm sm:text-base" data-touch-scroll-guard="true" data-gtm-event="cta_click" data-click-content="Jump to All Books">
              Jump to All Books
            </a>
          </div>

          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {topCategories.map((category) => (
              <a
                href={getCategoryPath(category.slug)}
                class="group rounded-2xl border border-gray-200 bg-gray-50 p-5 transition-all duration-300 hover:-translate-y-1 hover:border-primary-200 hover:bg-primary-50 hover:shadow-lg"
                data-touch-scroll-guard="true"
                data-gtm-event="category_click"
                data-click-content={category.name}
              >
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-gray-500">Category</p>
                    <h3 class="mt-2 text-xl font-semibold text-gray-900 group-hover:text-primary-700">{category.name}</h3>
                  </div>
                  <span class="rounded-full bg-white px-3 py-1 text-sm font-semibold text-primary-700 shadow-sm">
                    {category.count}
                  </span>
                </div>

                <p class="mt-4 text-sm text-gray-600 line-clamp-2">
                  Explore {category.count} summary{category.count === 1 ? "" : "ies"} connected by {category.name.toLowerCase()}.
                </p>

                <div class="mt-5 flex items-center text-sm font-semibold text-primary-600 group-hover:text-primary-700">
                  <span>View category</span>
                  <svg class="ml-2 h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {books.length === 0 ? (
        <div class="text-center py-16 sm:py-20">
          <div class="w-20 h-20 sm:w-24 sm:h-24 bg-gray-200 rounded-full flex items-center justify-center mx-auto mb-3 sm:mb-4">
            <svg class="w-10 h-10 sm:w-12 sm:h-12 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
            </svg>
          </div>
          <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-2">No books yet</h3>
          <p class="text-gray-600">Check back soon for new book summaries!</p>
        </div>
      ) : (
        <div id="all-books" class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary-600">All Summaries</p>
            <h2 class="mt-2 text-2xl sm:text-3xl font-bold text-gray-900">Browse every book across every category</h2>
          </div>
          <p class="max-w-xl text-sm sm:text-base text-gray-600">
            Each card now carries its category tags, so you can jump from an individual book to broader subject clusters.
          </p>
        </div>

        <div class="grid gap-4 sm:gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {books.map((book) => (
            <BookCard book={book} variant="catalog" showTags={true} tagLimit={3} />
          ))}
        </div>
      )}
      <!-- Call to Action -->
      {books.length > 0 && (
        <div class="text-center mt-12 sm:mt-16 p-6 sm:p-8 bg-white rounded-2xl shadow-sm">
          <h3 class="text-xl sm:text-2xl font-semibold text-gray-900 mb-3 sm:mb-4">Can't find what you're looking for?</h3>
          <p class="text-gray-600 mb-4 sm:mb-6 px-4 sm:px-0">We're constantly adding new book summaries. Request a book and we'll prioritize it!</p>
          <button id="open-request-modal" type="button" class="btn-secondary inline-flex items-center space-x-2 px-4 py-2.5 sm:px-6 sm:py-3 rounded-xl font-semibold text-sm sm:text-base" data-touch-scroll-guard="true" data-gtm-event="request_book_click" data-click-content="Request a Book">
            <span>Request a Book</span>
            <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
            </svg>
          </button>
          <div id="request-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 hidden">
            <div class="bg-white rounded-xl shadow-lg p-4 sm:p-6 w-full max-w-2xl relative">
              <button id="close-request-modal" type="button" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
              <h4 class="text-lg font-semibold mb-2">Request a Book</h4>
              <iframe src="https://docs.google.com/forms/d/e/1FAIpQLScgjIXlYnaHdqYj-in8hSxdoEhQu-kMmX8t4uOj5zAMHvP6tg/viewform?embedded=true" width="100%" height="419" frameborder="0" marginheight="0" marginwidth="0" class="w-full rounded-lg border">Loading…</iframe>
            </div>
          </div>
  <script is:inline>
    const openBtn = document.getElementById('open-request-modal');
    const modal = document.getElementById('request-modal');
    const closeBtn = document.getElementById('close-request-modal');
    if (openBtn && modal && closeBtn) {
      openBtn.onclick = () => { modal.classList.remove('hidden'); };
      closeBtn.onclick = () => { modal.classList.add('hidden'); };
      modal.onclick = (e) => { if (e.target === modal) closeBtn.onclick(); };
    }
  </script>
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter Section -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 sm:pb-16">
    <Newsletter 
      variant="compact"
      title="Never Miss a New Summary"
      subtitle="Get notified when we add new book summaries to our collection."
    />
  </div>
</Layout>
