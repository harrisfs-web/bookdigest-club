---
import type { CollectionEntry } from "astro:content";
import { getBookPath } from "../lib/bookCategories";

type BookEntry = CollectionEntry<"books">;

type Props = {
  books: BookEntry[];
};

const { books } = Astro.props as Props;
---
<section class="relative" data-bookshelf-root>
  <div
    class="overflow-x-auto pb-4 [scrollbar-width:thin] [scrollbar-color:#94a3b8_#e2e8f0] snap-x snap-proximity [scroll-behavior:smooth] [overscroll-behavior-x:contain]"
    aria-label="Book cover shelf"
    data-bookshelf-scroll
  >
    <ul class="flex min-w-max gap-4 px-1 sm:gap-5">
      {books.map((book) => (
        <li class="group w-28 shrink-0 snap-start sm:w-32">
          <a
            href={getBookPath(book.slug)}
            class="block"
          >
            <img
              src={book.data.cover}
              alt={`${book.data.title} cover`}
              loading="lazy"
              class="h-40 w-full rounded-lg object-cover shadow-md transition-transform duration-300 group-hover:-translate-y-1 group-hover:shadow-xl sm:h-48"
            />
            <p class="mt-2 line-clamp-2 text-xs font-medium text-gray-700 transition-colors group-hover:text-primary-700 sm:text-sm">
              {book.data.title}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="pointer-events-none absolute inset-y-0 left-0 w-10 bg-gradient-to-r from-gray-50 to-transparent sm:w-14" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-10 bg-gradient-to-l from-gray-50 to-transparent sm:w-14" aria-hidden="true"></div>
</section>

<script is:inline>
(function () {
  const roots = document.querySelectorAll('[data-bookshelf-root]');
  if (!roots.length) return;

  roots.forEach((root) => {
    const scroller = root.querySelector('[data-bookshelf-scroll]');
    if (!scroller) return;

    let touchActive = false;
    let moved = false;
    let touchStartX = 0;
    let touchStartY = 0;
    let scrollStartLeft = 0;
    let suppressUntil = 0;

    scroller.addEventListener('touchstart', (event) => {
      const touch = event.touches && event.touches[0];
      if (!touch) return;

      touchActive = true;
      moved = false;
      touchStartX = touch.clientX;
      touchStartY = touch.clientY;
      scrollStartLeft = scroller.scrollLeft;
    }, { passive: true });

    scroller.addEventListener('touchmove', (event) => {
      if (!touchActive || moved) return;

      const touch = event.touches && event.touches[0];
      if (!touch) return;

      const dx = Math.abs(touch.clientX - touchStartX);
      const dy = Math.abs(touch.clientY - touchStartY);
      const scrollDelta = Math.abs(scroller.scrollLeft - scrollStartLeft);

      // Mark as swipe when horizontal intent or actual horizontal scrolling is detected.
      if ((dx > 8 && dx >= dy) || scrollDelta > 6) {
        moved = true;
      }
    }, { passive: true });

    scroller.addEventListener('scroll', () => {
      if (!touchActive) return;

      const scrollDelta = Math.abs(scroller.scrollLeft - scrollStartLeft);
      if (scrollDelta > 2) {
        // Any touch-driven scrolling should suppress the synthetic click that follows.
        suppressUntil = Date.now() + 500;
      }
    }, { passive: true });

    scroller.addEventListener('touchend', () => {
      if (touchActive && moved) {
        suppressUntil = Date.now() + 500;
      }

      touchActive = false;
      moved = false;
    }, { passive: true });

    scroller.addEventListener('touchcancel', () => {
      touchActive = false;
      moved = false;
    }, { passive: true });

    root.addEventListener('click', (event) => {
      if (Date.now() > suppressUntil) return;

      const target = event.target;
      const link = target && target.closest ? target.closest('a[href]') : null;
      if (!link) return;

      event.preventDefault();
      event.stopPropagation();
    }, true);
  });
})();
</script>
