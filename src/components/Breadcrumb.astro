---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6 sm:mb-8 text-sm">
  <ol class="flex flex-wrap items-center gap-1.5 text-primary-200">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <span aria-hidden="true" class="text-primary-400 select-none">›</span>
        )}
        {index === items.length - 1 ? (
          <span class="text-white font-medium truncate max-w-[200px] sm:max-w-none" aria-current="page">
            {item.label}
          </span>
        ) : (
          <a href={item.href ?? '/'} class="hover:text-white transition-colors">
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
