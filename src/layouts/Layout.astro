---
/*  ADD THIS import so Astro bundles the file  */
import "../styles/global.css";
import SearchPopover from "../components/SearchPopover.astro";
import { getCollection } from "astro:content";
import { getBookCategories, getCategoryPath } from "../lib/bookCategories";

const defaultDescription = "AI-powered concise book summaries & recommendations.";
const {
  title = "BookDigest",
  description = defaultDescription,
  ogImage = "/og-default.svg",
  ogType = "website",
  author,
  keywords,
  robots = "index, follow, max-image-preview:large",
} = Astro.props;

const books = await getCollection("books");
const footerCategories = getBookCategories(books);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-K87VK2MC');</script>
    <!-- End Google Tag Manager -->

    <title>{title}</title>
    <meta name="description" content={description} />
    
  <!-- Canonical & robots -->
  <link rel="canonical" href={`https://bookdigest.club${Astro.url.pathname}`} />
  <meta name="robots" content={robots} />
  {author && <meta name="author" content={author} />}
  {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
  <link rel="alternate" type="application/rss+xml" title="BookDigest" href="/rss.xml" />

    <!-- Google Fonts -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Basic Open Graph -->
    <meta property="og:type"        content={ogType} />
    <meta property="og:site_name"   content="BookDigest" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage.startsWith('http') ? ogImage : `https://bookdigest.club${ogImage}`} />
  <meta property="og:url"         content={`https://bookdigest.club${Astro.url.pathname}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage.startsWith('http') ? ogImage : `https://bookdigest.club${ogImage}`} />

  <!-- Page-specific head content (e.g., JSON-LD) -->
  <slot name="head" />
  </head>

  <script>
  // Respect CMP consent when pushing custom events to the dataLayer.
  window.dataLayer = window.dataLayer || [];

  (function(){
    const dl = window.dataLayer;
    const queue = [];
    const touchGuardSelector = '[data-touch-scroll-guard]';
    const touchGuardState = {
      activeTarget: null,
      moved: false,
      startX: 0,
      startY: 0,
      suppressUntil: 0,
    };

    function getTouchGuardTarget(target){
      if (!target) return null;
      if (target.nodeType === 3 && target.parentElement) return target.parentElement.closest(touchGuardSelector);
      return target.closest ? target.closest(touchGuardSelector) : null;
    }

    function hasCMPSignals(){
      if (window.Usercentrics || window.__uc) return true;
      for(let i = dl.length - 1; i >= 0; i--) {
        const obj = dl[i];
        if (!obj || typeof obj !== 'object') continue;
        if (obj.ucCategory || obj.consent_status || obj.event === 'consent' || obj['Usercentrics']) return true;
      }
      return false;
    }

    function consentGranted(){
      // Inspect the dataLayer for common consent signals.
      for(let i = dl.length - 1; i >= 0; i--) {
        const obj = dl[i];
        if (!obj || typeof obj !== 'object') continue;
        // Usercentrics often pushes ucCategory with flags
        if (obj.ucCategory && typeof obj.ucCategory === 'object'){
          for(const k in obj.ucCategory){
            if (/(analytics|google)/i.test(k)) return !!obj.ucCategory[k];
          }
        }
        // Some CMPs push a top-level 'Google Analytics' boolean
        if (typeof obj['Google Analytics'] !== 'undefined') return !!obj['Google Analytics'];
        // Consent mode style push
        if (obj.event === 'consent' && obj.analytics_storage === 'granted') return true;
        if (obj.event === 'consent_status' && typeof obj.status !== 'undefined') return !!obj.status;
      }

      // If there are CMP signals but no explicit grant found, treat as denied.
      if (hasCMPSignals()) return false;
      // No CMP detected — assume allowed (preserve current behaviour)
      return true;
    }

    // Exposed helper that queues or pushes depending on consent
    window.bd = {
      track(eventName, params = {}){
        const payload = { event: eventName, ...params };
        try{
          if (consentGranted()){
            dl.push(payload);
          } else {
            queue.push(payload);
          }
        }catch(e){
          // fallback: push so we don't lose events if something unexpected happens
          dl.push(payload);
        }
        return payload;
      },
      _queue: queue,
      _consentGranted: consentGranted
    };

    // Wrap dataLayer.push to observe consent changes — flush queue when consent becomes granted
    if (dl && typeof dl.push === 'function'){
      const origPush = dl.push.bind(dl);
      dl.push = function(...args){
        const res = origPush(...args);
        try{
          // if consent now granted, flush queued events
          if (consentGranted() && queue.length){
            while(queue.length) origPush(queue.shift());
          }
        }catch(e){}
        return res;
      }
    }

    document.addEventListener('touchstart', (e) => {
      const target = getTouchGuardTarget(e.target);
      if (!target) {
        touchGuardState.activeTarget = null;
        touchGuardState.moved = false;
        return;
      }

      const touch = e.touches && e.touches[0];
      if (!touch) return;

      touchGuardState.activeTarget = target;
      touchGuardState.moved = false;
      touchGuardState.startX = touch.clientX;
      touchGuardState.startY = touch.clientY;
    }, { passive: true });

    document.addEventListener('touchmove', (e) => {
      if (!touchGuardState.activeTarget || touchGuardState.moved) return;

      const touch = e.touches && e.touches[0];
      if (!touch) return;

      const dx = Math.abs(touch.clientX - touchGuardState.startX);
      const dy = Math.abs(touch.clientY - touchGuardState.startY);

      if (dx > 12 || dy > 12) {
        touchGuardState.moved = true;
        touchGuardState.suppressUntil = Date.now() + 450;
      }
    }, { passive: true });

    document.addEventListener('touchend', () => {
      touchGuardState.activeTarget = null;
    }, { passive: true });

    document.addEventListener('touchcancel', () => {
      touchGuardState.activeTarget = null;
      touchGuardState.moved = false;
    }, { passive: true });

    document.addEventListener('click', (e) => {
      const guardedTarget = getTouchGuardTarget(e.target);
      if (!guardedTarget) return;
      if (!touchGuardState.moved && Date.now() > touchGuardState.suppressUntil) return;

      e.preventDefault();
      e.stopPropagation();
      touchGuardState.moved = false;
      touchGuardState.suppressUntil = 0;
    }, true);

    // Delegated handler for elements annotated with data-gtm-event.
    document.addEventListener('click', (e) => {
      try {
        if (e.defaultPrevented) return;
        let target = e.target;
        if (target && target.nodeType === 3 && target.parentElement) target = target.parentElement;
        const el = target && target.closest ? target.closest('[data-gtm-event]') : null;
        if (!el) return;

        const eventName = el.getAttribute('data-gtm-event');
        const clickContent = el.getAttribute('data-click-content') || (el.textContent || '').trim();

        if (el.tagName === 'A' && el.href) {
          e.preventDefault();
          window.bd.track(eventName, { click_content: clickContent });
          const opensNewTab = el.target === '_blank' || el.target === '_new';
          if (opensNewTab) {
            setTimeout(() => { window.open(el.href, '_blank', 'noopener,noreferrer'); }, 150);
          } else {
            setTimeout(() => { window.location.href = el.href; }, 150);
          }
        } else {
          window.bd.track(eventName, { click_content: clickContent });
        }
      } catch (err) {
        console.warn('bd track error', err);
      }
    }, { passive: false });

  })();
  </script>

  <body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen font-sans overflow-x-hidden">
  <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K87VK2MC"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    
    <!-- Navigation Header -->
    <header class="bg-white/80 backdrop-blur-sm border-b border-gray-200 sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between gap-2">
          <a href="/" aria-label="BookDigest Home" class="flex items-center gap-2 text-xl sm:text-2xl font-bold text-primary-700 hover:text-primary-800 transition-colors flex-shrink-0" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="Home">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
            </svg>
            <span class="hidden sm:inline">BookDigest</span>
          </a>
          <div class="flex items-center gap-2 sm:gap-6 flex-nowrap">
            <a href="/books" class="text-gray-600 hover:text-primary-600 font-medium transition-colors whitespace-nowrap" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="All Books">All Books</a>
            <a href="/about" class="text-gray-600 hover:text-primary-600 font-medium transition-colors whitespace-nowrap" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="About">About</a>
            <SearchPopover buttonClassName="sm:min-w-[190px] justify-between px-3.5" />
          </div>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 bg-gray-900 text-gray-300">
      <div class="max-w-6xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
        <div class="grid gap-8 md:grid-cols-2">
          <div>
            <a href="/" class="inline-flex items-center gap-2 text-xl font-bold text-white transition-colors hover:text-accent-300" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="Home Footer">
              <svg class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
              </svg>
              <span>BookDigest</span>
            </a>
            <p class="mt-3 max-w-md text-sm text-gray-400">
              AI-powered concise summaries that help you learn the core ideas from important books faster.
            </p>
            <p class="mt-4 text-sm text-gray-500">&copy; 2026 BookDigest. Built for curious, busy readers.</p>
          </div>

          <div class="grid grid-cols-2 gap-8 sm:gap-12">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-300">Explore</h3>
              <ul class="mt-4 space-y-2 text-sm">
                <li><a href="/" class="text-gray-400 transition-colors hover:text-white" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="Home Footer">Home</a></li>
                <li><a href="/books" class="text-gray-400 transition-colors hover:text-white" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="All Books Footer">All Books</a></li>
                <li><a href="/about" class="text-gray-400 transition-colors hover:text-white" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="About Footer">About</a></li>
                <li><a href="/rss.xml" class="text-gray-400 transition-colors hover:text-white" data-touch-scroll-guard="true" data-gtm-event="menu_click" data-click-content="RSS Footer">RSS Feed</a></li>
              </ul>
            </div>

            <div>
              <h3 class="text-sm font-semibold uppercase tracking-[0.16em] text-gray-300">Categories</h3>
              <ul class="mt-4 space-y-2 text-sm">
                {footerCategories.map((category) => (
                  <li>
                    <a
                      href={getCategoryPath(category.slug)}
                      class="text-gray-400 transition-colors hover:text-white"
                      data-touch-scroll-guard="true"
                      data-gtm-event="category_click"
                      data-click-content={category.name}
                    >
                      {category.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>